# LLM
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_FAST_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=120
MAX_RETRIES=2

# MCP / AKShare tools
MCP_TRANSPORT=stdio
MCP_SERVER_URL=http://localhost:8080
MCP_STDIO_ARGS=-m akshare_mcp_server
MCP_CONNECT_TIMEOUT=10
MCP_SSE_READ_TIMEOUT=300
MCP_TOOL_TIMEOUT=120

# Agent switches
MACRO_AGENT_ENABLED=false
DATA_FRESHNESS_CHECK_ENABLED=true

# Local data cache
LOCAL_DATA_STORE_ENABLED=true
LOCAL_DATA_STORE_READ_THROUGH=true
LOCAL_DATA_STORE_WRITE_THROUGH=true
LOCAL_DATA_STORE_HISTORY_ENABLED=true

# RQData offline stores
RQDATA_STORE_ENABLED=true
RQDATA_STORE_DIR=outputs/raw_rqdatac_database
RQDATA_TECHNICAL_STORE_DIR=outputs/raw_rqdatac_technical_indicators
